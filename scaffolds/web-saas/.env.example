# Public site URL (used for OG meta and absolute links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase --------------------------------------------------------
# Public — exposed to the browser, used by @supabase/supabase-js client
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# Server-only — service role for trusted server inserts (lead form, etc.)
# Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Direct DB URL — only needed if you wire Prisma/Drizzle in later
# DATABASE_URL=postgres://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# DIRECT_URL=postgres://postgres:<pw>@db.<ref>.supabase.co:5432/postgres

# --- Sentry ----------------------------------------------------------
# Same DSN for client + server (one project per product, see cookbook recipe 06)
NEXT_PUBLIC_SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project-id>
SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project-id>

# Build-time auth token for sourcemap upload (set in CI / Vercel env, not .env.local)
# SENTRY_AUTH_TOKEN=<auth-token>
SENTRY_ORG=<org-slug>
SENTRY_PROJECT=<project-slug>

# --- GA4 -------------------------------------------------------------
# Public — measurement ID exposed to gtag.js
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Server-only — Measurement Protocol API secret for server-side events
GA4_API_SECRET=<measurement-protocol-secret>

# --- Telegram (optional, for instant lead alerts) --------------------
# Create a bot via @BotFather, get the token, then start a chat and find chat_id
# Leave both blank to skip Telegram notifications without breaking the form
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
