{
  "name": "claude-operator-stack",
  "version": "0.1.0",
  "description": "Wizard installer for the Claude Operator Stack — a curated stack of skills, agents, MCP servers, and operator workflows for Claude Code.",
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "cli",
    "installer",
    "wizard",
    "skills",
    "agents",
    "mcp",
    "operator-stack"
  ],
  "homepage": "https://github.com/mccarthy606/claude-operator-stack#readme",
  "bugs": {
    "url": "https://github.com/mccarthy606/claude-operator-stack/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mccarthy606/claude-operator-stack.git",
    "directory": "packages/cli"
  },
  "license": "MIT",
  "author": "Dmitry McCarthy <https://github.com/mccarthy606>",
  "type": "module",
  "bin": {
    "claude-operator-stack": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/cli.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
