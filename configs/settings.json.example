{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "_comment": "Minimal settings.json template. Copy to ~/.claude/settings.json. Replace ${HOME} interpolations as needed by your shell or installer.",

  "permissions": {
    "_comment": "Pre-allow common safe read/write operations to reduce permission prompts. Audit and trim to your comfort level."
  },

  "env": {
    "DISABLE_TELEMETRY": "0",
    "MAX_THINKING_TOKENS": "16000"
  },

  "_enabledPlugins_note": "The stack ships 1 required plugin (Frontend-Design) and 2 opt-in plugins (Everything Claude Code, Toprank). The required plugin is enabled by default. Opt-ins are commented out via _disabled keys — flip them to true after running the matching '/plugin marketplace add' + '/plugin install' commands inside Claude Code.",

  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "_disabled_everything-claude-code@everything-claude-code": "set to true after /plugin install everything-claude-code@everything-claude-code (broad skill + agent catalog)",
    "_disabled_toprank@nowork-studio": "set to true after /plugin install toprank@nowork-studio (SEO + paid ads skill cluster)"
  },

  "_hooks_note": "Hooks are intentionally omitted from this template. ECC ships a comprehensive hook suite that auto-loads when its plugin is enabled. Add your own custom hooks under 'hooks' here only when you want to layer on top of ECC's defaults.",

  "hooks": {
    "_PreToolUse_example": "Custom safety guards or formatters can go here. See ECC's repo for the standard set.",
    "_PostToolUse_example": "Auto-format / type-check after edits. Run language-specific tools per the rules in /rules/.",
    "_Stop_example": "Final verification at session end (e.g., quick build check)."
  },

  "_rules_note": "Project-wide rules live in ~/.claude/rules/. This stack ships /configs/rules/obsidian-integration.md as a starting point — copy to ~/.claude/rules/ to enable.",

  "_workflow_pin": "If you want a specific skill or plugin to be checked at session start, add a 'sessionStart' hook here pointing to its entrypoint."
}
