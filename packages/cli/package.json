  "_publishNote": "Publish is intentionally NOT triggered by this package version (0.1.0). The package is built and locally runnable. Publishing coordinates with the public visibility flip in Phase 9 — do not run `npm publish` from this phase.",
  "scripts": {
    "build": "tsup",
